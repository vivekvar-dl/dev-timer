#!/usr/bin/env bash
# dev-timer - A simple Pomodoro timer for the terminal
set -euo pipefail

VERSION="1.3.0"

# Default values (in minutes)
WORK_TIME=25
SHORT_BREAK=5
LONG_BREAK=15
SESSIONS_UNTIL_LONG=4

# Stats file location
STATS_DIR="${HOME}/.dev-timer"
STATS_FILE="${STATS_DIR}/sessions.log"

show_help() {
    cat << EOF
dev-timer v${VERSION}

A simple Pomodoro timer for the terminal.

Usage: dev-timer [OPTIONS] [COMMAND]

Commands:
    start       Start a work session (default)
    break       Start a short break
    long        Start a long break
    custom MIN  Start a custom timer
    stats       Show session statistics
    export      Export session data
    reset       Reset session statistics

Options:
    -w, --work MIN        Work session length (default: 25)
    -s, --short MIN       Short break length (default: 5)
    -l, --long MIN        Long break length (default: 15)
    -g, --goal "TEXT"     Set a goal/description for this session
    -n, --notify          Send system notification when complete
    -q, --quiet           Suppress sound
    -h, --help            Show this help
    -v, --version         Show version

Export formats:
    dev-timer export --csv [FILE]         # Export to CSV (default: sessions.csv)
    dev-timer export --json [FILE]        # Export to JSON (default: sessions.json)

Examples:
    dev-timer                              # Start 25-minute work session
    dev-timer -g "Fix bug #123"            # Work session with goal
    dev-timer break                        # Start 5-minute break
    dev-timer custom 10                    # Custom 10-minute timer
    dev-timer -w 50 start                  # 50-minute work session
    dev-timer stats                        # View session statistics
    dev-timer stats --today                # Today's sessions only
    dev-timer stats --goals                # Show sessions with goals
    dev-timer export --csv                 # Export to CSV
    dev-timer export --json stats.json     # Export to JSON file

EOF
}

init_stats() {
    mkdir -p "$STATS_DIR"
    touch "$STATS_FILE"
}

log_session() {
    local type="$1"
    local minutes="$2"
    local goal="${3:-}"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    local date=$(date '+%Y-%m-%d')
    
    init_stats
    echo "${timestamp}|${date}|${type}|${minutes}|${goal}" >> "$STATS_FILE"
}

show_stats() {
    if [[ ! -f "$STATS_FILE" ]]; then
        echo "📊 No sessions recorded yet!"
        echo "Start a timer to begin tracking."
        return
    fi
    
    local show_today_only=false
    local show_goals_only=false
    
    # Parse stats options
    while [[ $# -gt 0 ]]; do
        case $1 in
            --today)
                show_today_only=true
                shift
                ;;
            --goals)
                show_goals_only=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done
    
    local total_sessions=$(wc -l < "$STATS_FILE")
    local work_sessions=$(grep -c '|work|' "$STATS_FILE" || echo 0)
    local break_sessions=$(grep -c '|break|' "$STATS_FILE" || echo 0)
    local total_minutes=$(awk -F'|' '{sum+=$4} END {print sum}' "$STATS_FILE")
    local total_hours=$(echo "scale=1; $total_minutes / 60" | bc)
    
    echo "📊 dev-timer Statistics"
    echo "======================="
    echo ""
    
    if [[ "$show_today_only" == false ]]; then
        echo "Total sessions:    $total_sessions"
        echo "Work sessions:     $work_sessions"
        echo "Break sessions:    $break_sessions"
        echo "Total time:        ${total_minutes} minutes (${total_hours} hours)"
        echo ""
    fi
    
    # Today's stats
    local today=$(date '+%Y-%m-%d')
    local today_sessions=$(grep -c "|${today}|" "$STATS_FILE" || echo 0)
    local today_minutes=$(grep "|${today}|" "$STATS_FILE" | awk -F'|' '{sum+=$4} END {print sum}')
    
    if [[ $today_sessions -gt 0 || "$show_today_only" == true ]]; then
        echo "Today ($today):"
        echo "  Sessions:        $today_sessions"
        echo "  Minutes:         ${today_minutes:-0}"
        echo ""
    fi
    
    # Show sessions with goals
    if [[ "$show_goals_only" == true ]]; then
        echo "Sessions with goals:"
        grep -v '||$' "$STATS_FILE" | while IFS='|' read -r timestamp date type minutes goal; do
            if [[ -n "$goal" ]]; then
                printf "  %s - %s (%dm): %s\n" "$timestamp" "$type" "$minutes" "$goal"
            fi
        done
    elif [[ "$show_today_only" == true ]]; then
        echo "Today's sessions:"
        grep "|${today}|" "$STATS_FILE" | while IFS='|' read -r timestamp date type minutes goal; do
            if [[ -n "$goal" ]]; then
                printf "  %s - %s (%dm): %s\n" "$timestamp" "$type" "$minutes" "$goal"
            else
                printf "  %s - %s (%dm)\n" "$timestamp" "$type" "$minutes"
            fi
        done
    else
        # Last 10 sessions
        echo "Recent sessions:"
        tail -10 "$STATS_FILE" | while IFS='|' read -r timestamp date type minutes goal; do
            if [[ -n "$goal" ]]; then
                printf "  %s - %s (%dm): %s\n" "$timestamp" "$type" "$minutes" "$goal"
            else
                printf "  %s - %s (%dm)\n" "$timestamp" "$type" "$minutes"
            fi
        done
    fi
    
    echo ""
    echo "Stats file: $STATS_FILE"
}

reset_stats() {
    if [[ -f "$STATS_FILE" ]]; then
        echo "⚠️  This will delete all session statistics."
        read -p "Are you sure? (y/N) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            rm "$STATS_FILE"
            echo "✨ Statistics reset!"
        else
            echo "Cancelled."
        fi
    else
        echo "No statistics to reset."
    fi
}

export_csv() {
    local output_file="${1:-sessions.csv}"
    
    if [[ ! -f "$STATS_FILE" ]]; then
        echo "❌ No sessions to export. Start a timer first!"
        return 1
    fi
    
    # Create CSV with headers
    echo "timestamp,date,type,minutes,goal" > "$output_file"
    
    # Convert pipe-delimited to CSV
    while IFS='|' read -r timestamp date type minutes goal; do
        # Escape quotes in goal field
        goal="${goal//\"/\"\"}"
        if [[ -n "$goal" ]]; then
            echo "\"$timestamp\",\"$date\",\"$type\",$minutes,\"$goal\"" >> "$output_file"
        else
            echo "\"$timestamp\",\"$date\",\"$type\",$minutes," >> "$output_file"
        fi
    done < "$STATS_FILE"
    
    local count=$(wc -l < "$STATS_FILE")
    echo "✅ Exported $count sessions to $output_file"
}

export_json() {
    local output_file="${1:-sessions.json}"
    
    if [[ ! -f "$STATS_FILE" ]]; then
        echo "❌ No sessions to export. Start a timer first!"
        return 1
    fi
    
    # Build JSON array
    echo "{" > "$output_file"
    echo "  \"sessions\": [" >> "$output_file"
    
    local first=true
    while IFS='|' read -r timestamp date type minutes goal; do
        if [[ "$first" == true ]]; then
            first=false
        else
            echo "," >> "$output_file"
        fi
        
        # Escape quotes and backslashes in strings
        timestamp="${timestamp//\\/\\\\}"
        timestamp="${timestamp//\"/\\\"}"
        date="${date//\\/\\\\}"
        date="${date//\"/\\\"}"
        type="${type//\\/\\\\}"
        type="${type//\"/\\\"}"
        goal="${goal//\\/\\\\}"
        goal="${goal//\"/\\\"}"
        
        echo -n "    {" >> "$output_file"
        echo -n "\"timestamp\":\"$timestamp\"," >> "$output_file"
        echo -n "\"date\":\"$date\"," >> "$output_file"
        echo -n "\"type\":\"$type\"," >> "$output_file"
        echo -n "\"minutes\":$minutes," >> "$output_file"
        echo -n "\"goal\":\"$goal\"" >> "$output_file"
        echo -n "}" >> "$output_file"
    done < "$STATS_FILE"
    
    echo "" >> "$output_file"
    echo "  ]," >> "$output_file"
    
    # Add summary statistics
    local total_sessions=$(wc -l < "$STATS_FILE")
    local work_sessions=$(grep -c '|work|' "$STATS_FILE" || echo 0)
    local break_sessions=$(grep -c '|break|' "$STATS_FILE" || echo 0)
    local total_minutes=$(awk -F'|' '{sum+=$4} END {print sum}' "$STATS_FILE")
    
    echo "  \"summary\": {" >> "$output_file"
    echo "    \"total_sessions\": $total_sessions," >> "$output_file"
    echo "    \"work_sessions\": $work_sessions," >> "$output_file"
    echo "    \"break_sessions\": $break_sessions," >> "$output_file"
    echo "    \"total_minutes\": $total_minutes" >> "$output_file"
    echo "  }" >> "$output_file"
    echo "}" >> "$output_file"
    
    echo "✅ Exported $total_sessions sessions to $output_file"
}

export_data() {
    local format=""
    local output_file=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --csv)
                format="csv"
                shift
                if [[ $# -gt 0 && ! "$1" =~ ^-- ]]; then
                    output_file="$1"
                    shift
                fi
                ;;
            --json)
                format="json"
                shift
                if [[ $# -gt 0 && ! "$1" =~ ^-- ]]; then
                    output_file="$1"
                    shift
                fi
                ;;
            *)
                echo "❌ Unknown export option: $1"
                echo "Usage: dev-timer export --csv [file] | --json [file]"
                return 1
                ;;
        esac
    done
    
    if [[ -z "$format" ]]; then
        echo "❌ Please specify export format: --csv or --json"
        echo "Usage: dev-timer export --csv [file] | --json [file]"
        return 1
    fi
    
    case "$format" in
        csv)
            export_csv "$output_file"
            ;;
        json)
            export_json "$output_file"
            ;;
    esac
}

notify_complete() {
    local message="$1"
    if command -v notify-send &> /dev/null; then
        notify-send "dev-timer" "$message"
    elif command -v osascript &> /dev/null; then
        osascript -e "display notification \"$message\" with title \"dev-timer\""
    fi
}

play_sound() {
    if [[ "$QUIET" == false ]]; then
        # Try various sound commands
        if command -v paplay &> /dev/null; then
            paplay /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null || true
        elif command -v afplay &> /dev/null; then
            afplay /System/Library/Sounds/Glass.aiff 2>/dev/null || true
        else
            echo -e '\a'  # Terminal bell
        fi
    fi
}

run_timer() {
    local minutes=$1
    local label=$2
    local type=$3
    local goal="${4:-}"
    local seconds=$((minutes * 60))
    
    echo "🍅 $label - $minutes minutes"
    if [[ -n "$goal" ]]; then
        echo "🎯 Goal: $goal"
    fi
    echo "Press Ctrl+C to cancel"
    echo ""
    
    local start_time=$(date +%s)
    local end_time=$((start_time + seconds))
    
    # Track if timer was completed
    local completed=false
    
    trap 'echo -e "\n\n⚠️  Timer cancelled."; exit 130' INT
    
    while [ $(date +%s) -lt $end_time ]; do
        local remaining=$((end_time - $(date +%s)))
        local mins=$((remaining / 60))
        local secs=$((remaining % 60))
        
        printf "\r⏱️  %02d:%02d remaining" $mins $secs
        sleep 1
    done
    
    completed=true
    
    echo -e "\n\n✨ $label complete!"
    if [[ -n "$goal" ]]; then
        echo "✅ Goal: $goal"
    fi
    play_sound
    
    if [[ "$NOTIFY" == true ]]; then
        notify_complete "$label complete!"
    fi
    
    # Log completed session
    log_session "$type" "$minutes" "$goal"
}

main() {
    local command="start"
    local NOTIFY=false
    local QUIET=false
    local GOAL=""
    local stats_args=()
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            -w|--work)
                WORK_TIME="$2"
                shift 2
                ;;
            -s|--short)
                SHORT_BREAK="$2"
                shift 2
                ;;
            -l|--long)
                LONG_BREAK="$2"
                shift 2
                ;;
            -g|--goal)
                GOAL="$2"
                shift 2
                ;;
            -n|--notify)
                NOTIFY=true
                shift
                ;;
            -q|--quiet)
                QUIET=true
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                echo "dev-timer v${VERSION}"
                exit 0
                ;;
            start|break|long|reset)
                command="$1"
                shift
                ;;
            stats)
                command="stats"
                shift
                # Collect remaining args for stats command
                while [[ $# -gt 0 ]]; do
                    stats_args+=("$1")
                    shift
                done
                ;;
            export)
                command="export"
                shift
                # Collect remaining args for export command
                while [[ $# -gt 0 ]]; do
                    stats_args+=("$1")
                    shift
                done
                ;;
            custom)
                command="custom"
                WORK_TIME="$2"
                shift 2
                ;;
            *)
                echo "Error: Unknown option $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    case "$command" in
        start)
            run_timer "$WORK_TIME" "Work session" "work" "$GOAL"
            ;;
        break)
            run_timer "$SHORT_BREAK" "Short break" "break" "$GOAL"
            ;;
        long)
            run_timer "$LONG_BREAK" "Long break" "long-break" "$GOAL"
            ;;
        custom)
            run_timer "$WORK_TIME" "Custom timer" "custom" "$GOAL"
            ;;
        stats)
            show_stats "${stats_args[@]}"
            ;;
        export)
            export_data "${stats_args[@]}"
            ;;
        reset)
            reset_stats
            ;;
    esac
}

main "$@"
